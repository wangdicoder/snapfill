@afterpaytouch:registry=https://nexus.corp.afterpay.com/repository/npm-internal/
@afterpay:registry=https://nexus.corp.afterpay.com/repository/npm-internal/
@arcade:registry=https://artifactory.global.square/artifactory/api/npm/npm-internal/
@squareup:registry=https://artifactory.global.square/artifactory/api/npm/npm-internal/
registry=https://artifactory.global.square/artifactory/api/npm/square-npm/
always-auth=true

# React Native / Metro requires all transitive deps to be resolvable via
# flat node_modules lookup. shamefully-hoist makes pnpm behave like npm/yarn.
# See: https://docs.expo.dev/guides/monorepos/#pnpm
shamefully-hoist=true
