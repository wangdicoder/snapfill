{
  "name": "@snapfill/react-native",
  "version": "0.1.0",
  "description": "React Native WebView adapter for @snapfill/core — hook and drop-in component",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@snapfill/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.70",
    "react-native-webview": ">=13"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": ["react-native", "webview", "autofill", "snapfill", "form-filling"]
}
